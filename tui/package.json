{
  "name": "langbridge-tui",
  "version": "0.1.0",
  "description": "LangBridge Code terminal UI (TypeScript / Ink)",
  "type": "module",
  "bin": {
    "langbridge-tui": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.tsx",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.18.0",
    "ink": "^5.2.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
